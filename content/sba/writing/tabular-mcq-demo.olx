<!-- content/demos/tabular-mcq-demo.xml -->
<Sequential id="writing_frequency_demo" title="Frequency of Writing Experiences" launchable="true">
   <Vertical id="Introduction">
       <Markdown>
            # Frequency of Past Writing Experiences
            Think about how often you do various kinds of writing.
            The next several screens ask you to estimate how often you write each type.
       </Markdown>
   </Vertical>
   <Vertical id="Step 1">
       <Markdown>
           # Writing For School
           Indicate how often you have engaged in each of the following activities **for school**.
       </Markdown>
       <TabularMCQ
         id="writing_frequency_1"
         rows="['Fiction (including drama, fan fiction and graphic novels)',
                'A list (e.g., to do list, grocery list)',
                'An essay',
                'A text message or direct message',
                'An annotated bibliography']"
         cols="['Daily', 'Weekly', 'Monthly', 'Every Semester', 'Rarely or Never']">
       </TabularMCQ>
       <Markdown>
         Select one option for each row. Your selections are automatically saved.
       </Markdown>
     </Vertical>

     <Vertical id="Step 2">
       <Markdown>
           # Writing Outside of School
           Indicate how often you have engaged in each of the following activities **outside of school**.
       </Markdown>
       <TabularMCQ
         id="writing_frequency_2"
         rows="['Fiction (including drama, fan fiction and graphic novels)',
                'A list (e.g., to do list, grocery list)',
                'An essay',
                'A text message or direct message',
                'An annotated bibliography']"
         cols="['Daily', 'Weekly', 'Monthly', 'Rarely', 'Never']">
       </TabularMCQ>
       <Markdown>
         Select one option for each row. Your selections are automatically saved.
       </Markdown>
     </Vertical>

